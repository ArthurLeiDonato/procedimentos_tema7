programa
{
 funcao vazio incrementarLocal()
 {
 inteiro contadorLocal = 0
 contadorLocal = contadorLocal + 1
 escreva("Valor local: ", contadorLocal + 3, "\n")
 escreva("Valor local: ", contadorLocal + 5, "\n")
 escreva("Valor local: ", contadorLocal + 6, "\n")
 }

 funcao inicio()
 {
 incrementarLocal()
 incrementarLocal()
 incrementarLocal()
 }
}